{
	"manifest_version": 3,
	"name": "Focus Override",
	"version": "1.2.0",
	"description": "Overrides visibility and focus APIs on targeted URLs.",
	"action": {},
	"background": {
		"service_worker": "background.js"
	},
	"host_permissions": [
		"https://gemini.google.com/*",
		"https://claude.ai/*",
		"https://grok.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://gemini.google.com/*",
				"https://claude.ai/*",
				"https://grok.com/*",
				"https://x.com/DavidJHarrisJr",
				"https://x.com/DavidJHarrisJr/*",
				"https://www.facebook.com/DavidJHarrisJr",
				"https://www.facebook.com/DavidJHarrisJr/*"
			],
			"js": [
				"content.js"
			],
			"run_at": "document_start",
			"world": "MAIN"
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'none';"
	}
}
