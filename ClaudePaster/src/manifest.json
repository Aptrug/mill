{
	"manifest_version": 3,
	"name": "Claude Paste Injector",
	"version": "1.0",
	"description": "Injects clipboard text into Claude.ai input, bypassing paste-to-document conversion.",
	"permissions": [
		"activeTab",
		"scripting",
		"clipboardRead"
	],
	"host_permissions": [
		"https://claude.ai/*"
	],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "Inject clipboard into Claude input"
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	}
}
